# ─── Server ─────────────────────────────────────────────────────────────
# NODE_ENV: development | production
# PORT: Vercel/Render will set this automatically; default 5000
NODE_ENV=development
PORT=5000

# ─── MongoDB ────────────────────────────────────────────────────────────
# Use MongoDB Atlas for production (free tier available)
# Format: mongodb+srv://<user>:<pass>@cluster.mongodb.net/khidma?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/khidma

# ─── JWT ────────────────────────────────────────────────────────────────
# Generate secure secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be 32+ characters for JWT_SECRET
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_REFRESH_EXPIRE=30d

# ─── Security ───────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
# Comma-separated list of allowed frontend origins
# Production: add your Vercel/deployed frontend URL
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.sa

# ─── Sentry (optional, leave blank to disable) ──────────────────────────
SENTRY_DSN=

# ─── File validation ────────────────────────────────────────────────────
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,application/pdf
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./src/uploads

# ─── Rate limits ────────────────────────────────────────────────────────
BOOKING_DAILY_LIMIT=15
UPLOAD_PER_MINUTE_LIMIT=10

# ─── Commission (do not change after launch without migration) ──────────
PLATFORM_COMMISSION_RATE=0.30
PROVIDER_COMMISSION_RATE=0.70

# ─── Booking expiry ─────────────────────────────────────────────────────
BOOKING_PAYMENT_DEADLINE_MINUTES=1440
PROVIDER_ACCEPT_DEADLINE_MINUTES=30

# ─── Admin bootstrap (used on first run only) ───────────────────────────
ADMIN_MUST_CHANGE_PASSWORD=true
ADMIN_EMAIL=admin@khidma.sa
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Platform Admin

# ─── Frontend URL (for CORS fallback) ───────────────────────────────────
# Must match your deployed frontend URL
FRONTEND_URL=http://localhost:5173
